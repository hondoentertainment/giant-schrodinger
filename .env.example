# Supabase (required for multiplayer rooms, shared rounds, and friend judgements)
# Solo play works without these, but multiplayer + sharing needs Supabase.
# Run supabase/schema.sql in your Supabase SQL editor to create tables + RLS policies.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini (for AI fusion image generation in dev; scoring uses server edge function in prod)
# Without this, the app uses mock scoring and curated images when server scoring is unavailable.
# VITE_GEMINI_API_KEY=your-gemini-api-key

# Production safety: keep client-side Gemini scoring disabled when Supabase is configured.
# Set only for local debugging: VITE_ALLOW_CLIENT_GEMINI=true

# Optional production telemetry (client-side)
# VITE_SENTRY_DSN=https://key@o123.ingest.sentry.io/project
# VITE_POSTHOG_KEY=phc_your_posthog_key
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# GitHub Actions hosted rehearsal (secrets, not .env)
# PRODUCTION_URL=https://giant-schrodinger.vercel.app

# Pexels (server-side only — set as a Supabase Edge Function secret, NOT a VITE_ var)
# Used by the resolve-image function for semantic stock photo lookup.
# PEXELS_API_KEY=your-pexels-api-key

# Giphy (server-side only — set as a Supabase Edge Function secret, NOT a VITE_ var)
# Used by the resolve-meme function for GIF/meme lookup in Memes & Videos mode.
# GIPHY_API_KEY=your-giphy-api-key

# Edge function CORS / OG (server-side)
# APP_URL=https://giant-schrodinger.vercel.app
# ALLOWED_ORIGINS=https://your-preview.vercel.app

# === Build-time Sentry (CI only; set as GitHub secrets, not in .env) ===
# When all three are set, `vite build` uploads hidden sourcemaps via @sentry/vite-plugin.
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=venn-with-friends

# Discord bot (edge secret — optional)
# DISCORD_PUBLIC_KEY=hex_public_key_from_discord_developer_portal

# Apply edge secrets from env: npm run configure:edge-secrets
