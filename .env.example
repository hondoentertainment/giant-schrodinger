# Supabase (required for multiplayer rooms, shared rounds, and friend judgements)
# Solo play works without these, but multiplayer + sharing needs Supabase.
# Run supabase/schema.sql in your Supabase SQL editor to create tables + RLS policies.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini (for AI scoring and fusion image generation)
# Without this, the app uses mock scoring and curated images.
VITE_GEMINI_API_KEY=your-gemini-api-key

# === Build-time Sentry (CI only; set as GitHub secrets, not in .env) ===
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=venn-with-friends

# === Staging (optional) ===
# These are used when building for the staging environment
# (staging/** and claude/** branches deploy to /giant-schrodinger/staging/).
# Leave unset for local dev or production builds.
# PUBLIC_ENV marks the runtime environment name exposed to CI tooling.
# VITE_APP_ENV is read by the client bundle (e.g. to show a "staging" banner).
# The *_STAGING variants let you point at a dedicated Supabase project so
# staging writes don't pollute production data.
# PUBLIC_ENV=staging
# VITE_APP_ENV=staging
# VITE_SUPABASE_URL_STAGING=https://your-staging-project.supabase.co
# VITE_SUPABASE_ANON_KEY_STAGING=your-staging-anon-key
