# Supabase (required for multiplayer rooms, shared rounds, and friend judgements)
# Solo play works without these, but multiplayer + sharing needs Supabase.
# Run supabase/schema.sql in your Supabase SQL editor to create tables + RLS policies.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini (for AI scoring and fusion image generation)
# Without this, the app uses mock scoring and curated images.
VITE_GEMINI_API_KEY=your-gemini-api-key

# Sentry (error monitoring). When empty, the Sentry SDK is not initialized
# and errors fall back to console.error / LocalStorage. Grab the DSN from
# your Sentry project settings. Release tagging is read from VITE_APP_VERSION.
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# PostHog (product analytics). When empty, analytics falls back to the
# in-dev console provider and nothing is sent off-device. Grab the project
# API key from PostHog project settings. The host defaults to US cloud.
# VITE_POSTHOG_KEY=phc_your-project-key
# VITE_POSTHOG_HOST=https://us.i.posthog.com
