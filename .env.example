# Supabase (required for multiplayer rooms, shared rounds, and friend judgements)
# Solo play works without these, but multiplayer + sharing needs Supabase.
# Run supabase/schema.sql in your Supabase SQL editor to create tables + RLS policies.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini (for AI scoring and fusion image generation)
# Without this, the app uses mock scoring and curated images.
VITE_GEMINI_API_KEY=your-gemini-api-key

# Pexels (server-side only — set as a Supabase Edge Function secret, NOT a VITE_ var)
# Used by the resolve-image function for semantic stock photo lookup.
# PEXELS_API_KEY=your-pexels-api-key

# Giphy (server-side only — set as a Supabase Edge Function secret, NOT a VITE_ var)
# Used by the resolve-meme function for GIF/meme lookup in Memes & Videos mode.
# GIPHY_API_KEY=your-giphy-api-key

# === Build-time Sentry (CI only; set as GitHub secrets, not in .env) ===
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=venn-with-friends
