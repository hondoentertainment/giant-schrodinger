# Supabase (required for multiplayer rooms, shared rounds, and friend judgements)
# Solo play works without these, but multiplayer + sharing needs Supabase.
# Run supabase/schema.sql in your Supabase SQL editor to create tables + RLS policies.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini (for AI scoring and fusion image generation)
# Without this, the app uses mock scoring and curated images.
# NOTE: In production, scoring is done server-side by the
# `score-submission` Edge Function. This client key is only used as a
# local-dev fallback when VITE_SUPABASE_URL is missing.
VITE_GEMINI_API_KEY=your-gemini-api-key

# ---------------------------------------------------------------------------
# Edge Function secrets (NOT VITE_ — never exposed to the browser).
# Set these with `supabase secrets set KEY=value` before deploying functions.
# ---------------------------------------------------------------------------

# Gemini API key used by the `score-submission` Edge Function.
# Either GEMINI_API_KEY or GOOGLE_GENERATIVE_AI_API_KEY is accepted.
# GEMINI_API_KEY=your-gemini-api-key

# Supabase service role key used by the `og-tags` Edge Function to read
# shared_rounds / challenges on behalf of crawlers. Server-side only.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public URL of the deployed SPA. The `og-tags` function redirects crawlers
# here after serving the meta tags. Defaults to the GitHub Pages URL.
# APP_URL=https://your-app.example.com

# Optional override for the default OG image used when a round has none.
# DEFAULT_OG_IMAGE=https://your-app.example.com/og-image.svg

# Sentry (error monitoring). When empty, the Sentry SDK is not initialized
# and errors fall back to console.error / LocalStorage. Grab the DSN from
# your Sentry project settings. Release tagging is read from VITE_APP_VERSION.
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# PostHog (product analytics). When empty, analytics falls back to the
# in-dev console provider and nothing is sent off-device. Grab the project
# API key from PostHog project settings. The host defaults to US cloud.
# VITE_POSTHOG_KEY=phc_your-project-key
# VITE_POSTHOG_HOST=https://us.i.posthog.com
